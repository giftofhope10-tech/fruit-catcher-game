<?xml version="1.0" encoding="utf-8"?>
<!--
    This library exists solely to guarantee com.google.android.gms.permission.AD_ID
    is declared in the final AAB.

    Plain declaration — no tools:node attribute. The Capacitor library manifests
    (@capacitor/android, @capacitor/app) are empty and do not declare AD_ID at
    all, so there is nothing to "replace". Using tools:node="replace" when there
    is no matching lower-priority node causes AGP 8.2.1 to silently drop the
    permission from the final merged manifest. A plain declaration is always
    preserved by the manifest merger.

    This file is committed to the repo and cannot be removed by cap sync or
    any Appflow build step.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

</manifest>
