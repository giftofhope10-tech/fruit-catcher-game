<?xml version="1.0" encoding="utf-8"?>
<!--
    This library exists solely to guarantee com.google.android.gms.permission.AD_ID
    survives Gradle manifest merging into the final AAB.

    tools:node="replace" gives this declaration the highest merge priority,
    overriding any library that uses tools:node="remove" on the same permission.

    This file is committed to the repo and cannot be removed by cap sync or
    Appflow's build environment.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="replace" />

</manifest>
