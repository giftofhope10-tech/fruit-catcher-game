<?xml version="1.0" encoding="utf-8"?>
<!--
    Build-type overlay merged ONLY into the release build.
    tools:node="replace" forces this declaration to win even if a library
    manifest has tools:node="remove" on AD_ID.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="replace" />

</manifest>
