<?xml version="1.0" encoding="utf-8"?>
<!--
    This manifest is merged ONLY into the release build type.
    It ensures the AD_ID permission is always present in production AABs,
    even if any library or plugin manifest tries to remove it.
    See: https://developer.android.com/studio/build/manifest-merge
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Required for Android 13+ (API 33) to access the Advertising ID (GAID).
        Google AdMob needs this to serve targeted ads and measure performance.
        Without it, advertising ID will be zeroed on Android 13+ devices.
    -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="merge" />

</manifest>
