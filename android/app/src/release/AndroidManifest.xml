<?xml version="1.0" encoding="utf-8"?>
<!--
    Build-type overlay merged ONLY into the release build.

    Plain declaration — no tools:node attribute. The Capacitor library manifests
    are empty, so tools:node="replace" was finding nothing to replace, causing
    AGP 8.2.1 to silently drop the permission. A plain declaration is always
    preserved in the merged manifest.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

</manifest>
