<?xml version="1.0" encoding="utf-8"?>
<!--
    Build-type overlay merged ONLY into the release build.

    tools:node="replace" — overrides any library manifest declaration for AD_ID,
    including any tools:node="remove" from Unity Ads, play-services-ads-identifier,
    or Capacitor. The :ad-id-compat module provides a lower-priority plain
    declaration so "replace" always has a valid target (avoids AGP 8.2.1
    silent-drop bug that occurs when there is nothing to replace).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID"
        tools:node="replace" />

</manifest>
